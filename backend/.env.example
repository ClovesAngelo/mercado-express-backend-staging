# MERCADO EXPRESS — BACKEND CONFIGURAÇÃO

# ===========================================
# BANCO DE DADOS
# ===========================================
# URL de conexão PostgreSQL (Supabase)
# Formato: postgresql://usuario:senha@host:5432/banco?schema=public
DATABASE_URL=postgresql://usuario:senha@localhost:5432/mercado_express?schema=public

# ===========================================
# JWT
# ===========================================
# Chave secreta para assinatura de tokens JWT
# MÍNIMO 32 CARACTERES - gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=coloque-aqui-uma-chave-secreta-forte-de-32-caracteres

# ===========================================
# SUPABASE
# ===========================================
# URL do projeto Supabase
SUPABASE_URL=https://seu-projeto.supabase.co

# Chave de serviço (privada) - usada no backend para admin Supabase
# NUNCA expor esta chave no frontend
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# ===========================================
# CORS
# ===========================================
# Origens permitidas (separadas por vírgula)
# Exemplo: http://localhost:5173,https://meusite.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ===========================================
# SERVIDOR
# ===========================================
# Porta da aplicação (padrão: 3000)
PORT=3000