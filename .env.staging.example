# MERCADO EXPRESS — CONFIGURAÇÃO DE STAGING

# ===========================================
# BANCO DE DADOS
# ===========================================
# URL de conexão PostgreSQL (Supabase ou outro)
# Formato: postgresql://usuario:senha@host:5432/banco?schema=public
DATABASE_URL=

# ===========================================
# JWT
# ===========================================
# Chave secreta para assinatura de tokens JWT
# MÍNIMO 32 CARACTERES
# NUNCA usar valor fixo em produção
JWT_SECRET=

# ===========================================
# SUPABASE
# ===========================================
# URL do projeto Supabase
SUPABASE_URL=

# Chave anônima (pública) - usada no frontend
SUPABASE_ANON_KEY=

# Chave de serviço (privada) - usada no backend
# NUNCA expor esta chave no frontend
SUPABASE_SERVICE_ROLE_KEY=

# ===========================================
# CORS
# ===========================================
# Origens permitidas (separadas por vírgula)
# Exemplo: https://mercadoexpress.com,https://admin.mercadoexpress.com
CORS_ORIGINS=

# ===========================================
# SERVIDOR
# ===========================================
# Porta da aplicação (padrão: 3000)
PORT=3000

# Ambiente (development | staging | production)
NODE_ENV=staging

# ===========================================
# COMO USAR
# ===========================================
# 1. Copie este arquivo: cp .env.staging.example .env.staging
# 2. Preencha todas as variáveis
# 3. Execute: npm run start:prod -- -c .env.staging
#    ou configure as variáveis no seu provedor de hosting