# Frontend staging environment example
# Copy this file to .env.staging and fill with real staging values.
# Do not commit .env.staging.

# Public API URL used by the Vite frontend.
# Example: https://api-staging.mercadoexpress.com.br
VITE_API_URL=

# Important:
# Only variables prefixed with VITE_ are exposed to the frontend bundle.
# Never put backend secrets here.
# Never put DATABASE_URL, JWT_SECRET, SUPABASE_SERVICE_ROLE_KEY, or private API keys here.